# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
SECRET_KEY=your-secret-key-here

# ── MongoDB (required for /packing/predict-orders) ────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=LogisticForesightDB
MONGO_DB_NAME=LogisticForesight

# ── Eureka (optional — leave blank to skip registration) ──────────────────────
EUREKA_SERVER=http://your-service-registry.onrender.com/eureka
INSTANCE_HOST=your-ml-service.onrender.com
